# System
CONFIG_CLOCK_CONTROL=y
CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

# IO
CONFIG_GPIO=y
CONFIG_PINCTRL=y
CONFIG_RTC=y
CONFIG_SERIAL=y
CONFIG_SPI=y
CONFIG_SPI_ASYNC=y
CONFIG_SPI_STM32_DMA=y
CONFIG_LED=y

CONFIG_USB_DEVICE_STACK_NEXT=y
# USB Serial
CONFIG_CDC_ACM_SERIAL_VID=0x181c
CONFIG_CDC_ACM_SERIAL_PID=0x0005
CONFIG_CDC_ACM_SERIAL_MANUFACTURER_STRING="Launch Initiative"
CONFIG_CDC_ACM_SERIAL_PRODUCT_STRING="Liquids Module"

# USB Serial Console
CONFIG_USBD_CDC_ACM_CLASS=y
CONFIG_CDC_ACM_SERIAL_INITIALIZE_AT_BOOT=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_STDOUT_CONSOLE=y
CONFIG_UART_LINE_CTRL=y